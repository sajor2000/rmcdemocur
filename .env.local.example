DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/rushmap?sslmode=require

# AI Innovation Foundry (nonprod) — deployment names must match portal
AZURE_OPENAI_ENDPOINT=https://rua-nonprod-ai-innovation.cognitiveservices.azure.com
AZURE_OPENAI_API_KEY=your-key
AZURE_OPENAI_DEPLOYMENT_CHAT=gpt-4.1
AZURE_OPENAI_DEPLOYMENT_EMBED=text-embedding-3-large
AZURE_OPENAI_EMBEDDING_DIMENSIONS=1536
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Optional: when set, ALL /api/* routes (reads and writes) require a credential.
# Server-to-server: send `Authorization: Bearer <API_SECRET>`. The browser is
# authenticated automatically via a short-lived HMAC session cookie issued on
# page load (fetch + EventSource work without code changes). Unset = fully open (dev).
API_SECRET=

# Optional retrieval relevance thresholds (default off — unset preserves prior behavior).
# Recalibrate after any re-embed with: npx tsx scripts/calibrate-thresholds.ts
# Values below were recalibrated 2026-07-04 on the full corpus (2906 chunks, 14 docs).
RETRIEVAL_MAX_DISTANCE=0.88   # max cosine distance for framework/keyword candidates (0–2); zero-alignment-loss guardrail
SEARCH_MIN_SIMILARITY=0.42    # min cosine similarity for search results (0–1); separates on-topic (>0.5) from off-topic (<0.29)
